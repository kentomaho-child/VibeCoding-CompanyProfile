# ==========================================================
# Single .gitignore for the whole repository (all subfolders)
# Uses **/ patterns so rules apply at root and in any subfolder
# ==========================================================

# Dependencies
node_modules/
**/node_modules/
.pnp
.pnp.js

# Build output
dist/
**/dist/
dist-ssr/
**/dist-ssr/
build/
**/build/
*.local

# Vite / cache
.vite/
**/.vite/
.cache/
**/.cache/
.temp/
.tmp/
.eslintcache
**/.eslintcache

# Logs
logs/
**/logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Environment variables
.env
.env.local
.env.*.local
**/.env
**/.env.local
**/.env.*.local

# Editor / OS files
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
Thumbs.db
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Testing / coverage
coverage/
**/coverage/
*.lcov
